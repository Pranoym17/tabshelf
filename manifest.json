{
  "manifest_version": 3,
  "name": "TabShelf",
  "version": "0.1.0",
  "description": "Save open tabs as persistent, zero-RAM project folders",
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "background": {
    "service_worker": "src/background/background.ts",
    "type": "module"
  },
  "options_page": "src/options/index.html",
  "permissions": ["tabs", "storage", "commands"],
  "commands": {
    "save-current-tabs": {
      "suggested_key": {
        "default": "Ctrl+Shift+S",
        "mac": "Command+Shift+S"
      },
      "description": "Save current tabs as a new folder"
    },
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+T",
        "mac": "Command+Shift+T"
      }
    }
  }
}
